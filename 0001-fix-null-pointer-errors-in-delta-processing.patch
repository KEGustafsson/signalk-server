+++ b/src/tokensecurity.js
@@ -568,6 +568,7 @@ module.exports = function (app, config) {
           (update.values &&
             update.values.find((valuePath) => {
               return (
+                valuePath &&
                 strategy.checkACL(
                   req.skPrincipal.identifier,
                   context,
@@ -580,6 +581,7 @@ module.exports = function (app, config) {
           (update.meta &&
             update.meta.find((valuePath) => {
